{
  "name": "mxn-translate-backend",
  "version": "1.0.0",
  "description": "Backend API for MXN Translate Discord Bot Dashboard",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
